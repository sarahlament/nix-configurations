# Nix build outputs
result
result-*

# direnv
.direnv/

# Claude Code local settings - ignore everything under .claude/ EXCEPT the
# project instructions, which are real documentation and should be reviewable.
# Must be `.claude/*` not `**/.claude/`: git cannot re-include a file whose
# parent directory is itself excluded, so a negation under the old rule silently
# did nothing.
.claude/*
!.claude/CLAUDE.md
# nested .claude dirs (worktree checkouts, etc.) stay fully ignored
**/*/.claude/

# Editor/IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Local notes/scratch and one-shot operational scripts (not tracked)
docs/
ceremony/

# Temporary files
*.tmp
*.bak
*.qcow2
bkup/

# Generated files
.pre-commit-config.yaml
