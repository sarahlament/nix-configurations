// niri config - repo-managed but MUTABLE via HM mkOutOfStoreSymlink.
// ~/.config/niri/config.kdl is a symlink to this file, so edit it live and niri
// hot-reloads on save - no rebuild. it's in the repo, so jj tracks it and borg
// backs it up. codify into typed programs.niri.settings later only if wanted.
// Full reference: https://yalter.github.io/niri/

input {
    keyboard {
        xkb {
            layout "us"
        }
        // NumLock on at startup
        numlock
    }
    // ishtar's a desktop, but these are harmless and ready if a laptop ever runs it
    touchpad {
        tap
        natural-scroll
    }
    mouse {
        natural-scroll
    }
}

// monitor layout: 1440p (DP-2, Asus PG27Q) on the LEFT, 1080p (DP-1, VG248) on the RIGHT.
// x=2560 puts DP-1 flush against DP-2's right edge. tops aligned (y=0).
// mode with resolution only (no @rate) = niri picks the highest refresh for it:
// DP-2 -> 165Hz, DP-1 -> 144Hz. no need to pin the exact 3-decimal rate.
output "DP-2" {
    mode "2560x1440"
    position x=0 y=0
}
output "DP-1" {
    mode "1920x1080"
    position x=2560 y=0
}

// noctalia IS the shell: bar, launcher, control center, lock, notifications, OSDs.
spawn-at-startup "noctalia"

// DPMS idle timer: monitors off after 5 min (300s) idle, back on with input.
spawn-at-startup "swayidle" "-w" "timeout" "300" "niri msg action power-off-monitors" "resume" "niri msg action power-on-monitors"

// niri auto-manages xwayland-satellite when the binary is present (it is), so
// steam / X11 apps get a rootless X server with no extra spawn needed here.

prefer-no-csd

cursor {
    hide-when-typing
    hide-after-inactive-ms 1500
}

screenshot-path "~/Pictures/Screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"

layout {
    gaps 16
    center-focused-column "never"
    preset-column-widths {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
    }
    default-column-width { proportion 0.5; }
    focus-ring {
        width 4
        active-color "#7fc8ff"
        inactive-color "#505050"
    }
    border {
        off
    }
}

binds {
    // --- launching ---
    Mod+Return hotkey-overlay-title="terminal" { spawn "kitty"; }
    Mod+T      hotkey-overlay-title="terminal" { spawn "kitty"; }
    Mod+B      hotkey-overlay-title="browser"  { spawn "zen-beta"; }
    Mod+Space  hotkey-overlay-title="launcher" { spawn "noctalia" "msg" "panel-toggle" "launcher"; }
    Mod+D      hotkey-overlay-title="launcher" { spawn "noctalia" "msg" "panel-toggle" "launcher"; }
    Mod+C      hotkey-overlay-title="control center" { spawn "noctalia" "msg" "panel-toggle" "control-center"; }
    Super+Alt+L hotkey-overlay-title="lock screen" { spawn "noctalia" "msg" "session" "lock"; }

    // --- focus (window/column) - vim hjkl ---
    Mod+H     { focus-column-left; }
    Mod+L     { focus-column-right; }
    Mod+K     { focus-window-up; }
    Mod+J     { focus-window-down; }

    // --- move (window/column) - vim hjkl ---
    Mod+Shift+H     { move-column-left; }
    Mod+Shift+L     { move-column-right; }
    Mod+Shift+K     { move-window-up; }
    Mod+Shift+J     { move-window-down; }

    // --- column stacking (shove focused window across the column boundary,
    //     consuming into the neighbor or expelling out, whichever applies) ---
    Mod+BracketLeft  { consume-or-expel-window-left; }
    Mod+BracketRight { consume-or-expel-window-right; }

    // --- monitors (dual-head: Ctrl focuses, Ctrl+Shift moves) - vim h/l ---
    Mod+Ctrl+H           { focus-monitor-left; }
    Mod+Ctrl+L           { focus-monitor-right; }
    Mod+Ctrl+Shift+H     { move-column-to-monitor-left; }
    Mod+Ctrl+Shift+L     { move-column-to-monitor-right; }

    // --- overview (niri's zoomed-out all-workspaces view) ---
    Mod+O { toggle-overview; }

    // --- workspaces ---
    Mod+U         { focus-workspace-down; }
    Mod+I         { focus-workspace-up; }
    // move the focused column down/up a workspace (relative, not numbered)
    Mod+Shift+U   { move-column-to-workspace-down; }
    Mod+Shift+I   { move-column-to-workspace-up; }

    // --- sizing ---
    Mod+R       { switch-preset-column-width; }
    Mod+F       { maximize-column; }
    Mod+Shift+F { fullscreen-window; }
    // window-level (not column-) so it also resizes floating windows; height too
    Mod+Minus         { set-window-width "-10%"; }
    Mod+Equal         { set-window-width "+10%"; }
    Mod+Shift+Minus   { set-window-height "-10%"; }
    Mod+Shift+Equal   { set-window-height "+10%"; }
    Mod+Comma   { consume-window-into-column; }
    Mod+Period  { expel-window-from-column; }

    // --- floating ---
    Mod+V       { toggle-window-floating; }
    Mod+Shift+V { switch-focus-between-floating-and-tiling; }

    // --- audio (wpctl ships with pipewire/wireplumber) ---
    XF86AudioRaiseVolume allow-when-locked=true { spawn "wpctl" "set-volume" "@DEFAULT_AUDIO_SINK@" "0.05+"; }
    XF86AudioLowerVolume allow-when-locked=true { spawn "wpctl" "set-volume" "@DEFAULT_AUDIO_SINK@" "0.05-"; }
    XF86AudioMute        allow-when-locked=true { spawn "wpctl" "set-mute" "@DEFAULT_AUDIO_SINK@" "toggle"; }

    // --- screenshots ---
    Print      { screenshot; }
    Ctrl+Print { screenshot-screen; }
    Alt+Print  { screenshot-window; }

    // --- session ---
    Mod+Q           { close-window; }
    Mod+Shift+Slash { show-hotkey-overlay; }
    Mod+Shift+E     { quit; }
}

// zen picture-in-picture floats instead of tiling
window-rule {
    match app-id="zen-beta" title="^Picture.in.Picture$"
    open-floating true
}

// discord pop-out (voice/video/stream) floats; the main window's title ends
// in "Discord", so exclude that to keep it tiled.
window-rule {
    match app-id="discord"
    exclude title="Discord$"
    open-floating true
}

// kitty is translucent (background_opacity in rice.conf). with prefer-no-csd,
// niri paints a solid backdrop behind decoration-less windows, which shows
// THROUGH the translucency as solid - turn it off so the wallpaper shows.
window-rule {
    match app-id="kitty"
    draw-border-with-background false
}
// absolute path (not relative "noctalia.kdl"): this file is symlinked in from the
// repo, and niri would resolve a relative include against the symlink target dir,
// missing noctalia's generated palette. noctalia writes noctalia.kdl to this exact
// path regardless of where config.kdl physically lives.
include "/home/lament/.config/niri/noctalia.kdl"
